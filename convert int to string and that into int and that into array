import java.util.Arrays;
public class Main {
    public static void main(String[] args) {
        int originalInt = 1234;
        String strValue = String.valueOf(originalInt);
        System.out.println("1. String value: " + strValue);

        int finalInt = Integer.parseInt(strValue);
        System.out.println("2. Integer value: " + finalInt);

        char[] charArray = strValue.toCharArray();

        System.out.print("3. Character array: ");
        System.out.println(Arrays.toString(charArray));
    }
}
